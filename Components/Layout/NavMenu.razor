@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand">QuickFix</a>
    </div>
</div>

<AuthorizeView>
    <Authorized>

        <input type="checkbox" title="Navigation menu" class="navbar-toggler" />

        <div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
            <nav class="nav flex-column">

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>
                        Home
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/tickets/new">
                        <span class="bi bi-plus-circle-fill"></span>
                        Create Ticket
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/settings">
                        <span class="bi bi-gear-fill"></span>
                        Settings
                    </NavLink>
                </div>

                <!-- ADMIN ONLY -->
                <AuthorizeView Context="authState">
                    @if (authState.User.IsInRole("Admin"))
                    {
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="/admin">
                                <span class="bi bi-speedometer2" aria-hidden="true"></span>
                                Admin Dashboard
                            </NavLink>
                        </div>
                    }
                </AuthorizeView>

            </nav>
        </div>

    </Authorized>

    <NotAuthorized>
        @* Sidebar stays visible but links are hidden *@
    </NotAuthorized>
</AuthorizeView>